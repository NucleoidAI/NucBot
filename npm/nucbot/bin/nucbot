#!/usr/bin/env node
// Resolves and runs the platform-specific nucbot binary.
const { execFileSync } = require("child_process");
const { platform, arch } = process;

const PLATFORM_MAP = {
  "linux-x64":    "nucbot-linux-x64",
  "linux-arm64":  "nucbot-linux-arm64",
  "darwin-x64":   "nucbot-darwin-x64",
  "darwin-arm64": "nucbot-darwin-arm64",
};

const key = `${platform}-${arch}`;
const pkg = PLATFORM_MAP[key];

if (!pkg) {
  console.error(`nucbot: unsupported platform ${key}`);
  process.exit(1);
}

let binPath;
try {
  binPath = require.resolve(`${pkg}/package.json`).replace("package.json", `nucbot-${key}`);
} catch {
  console.error(`nucbot: platform package "${pkg}" is not installed.`);
  console.error(`Try: npm install ${pkg}`);
  process.exit(1);
}

try {
  execFileSync(binPath, process.argv.slice(2), { stdio: "inherit" });
} catch (e) {
  process.exit(e.status ?? 1);
}
